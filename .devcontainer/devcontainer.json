{
  "name": "my-ai-app-ubuntu",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": ".."
  },
  "workspaceFolder": "/app",
  "workspaceMount": "source=${localWorkspaceFolder},target=/app,type=bind",
  "runArgs": [
    "-p",
    "5173:5173",
    "-p",
    "8000:8000",
    "-p",
    "5433:5432",
    "-p",
    "6277:6277",
    "-p",
    "6274:6274",
    "-v",
    "ai_postgres_data:/var/lib/postgresql/data",
    "-v",
    "ai_frontend_node_modules:/app/frontend/node_modules"
  ],
  "containerEnv": {
    "POSTGRES_USER": "app",
    "POSTGRES_PASSWORD": "1q2w3e4r!",
    "POSTGRES_DB": "ai_app",
    "DATABASE_URL": "postgresql+psycopg://app:1q2w3e4r%21@localhost:5432/ai_app",
    "BACKEND_HOST": "0.0.0.0",
    "BACKEND_PORT": "8000",
    "FRONTEND_PORT": "5173",
    "VITE_API_BASE_URL": "http://localhost:8000",
    "OPENAI_API_KEY": "your_api_key_here"
  },
  "postCreateCommand": "dos2unix /app/start.sh && chmod +x /app/start.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-azuretools.vscode-docker",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint"
      ]
    }
  }
}